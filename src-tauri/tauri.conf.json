{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CSV2DMLI",
  "version": "0.1.0",
  "identifier": "br.com.csv2dmli.dicionario",
  "build": {
    "frontendDist": "../dist-desktop",
    "devUrl": "http://localhost:8080/index-wizard.html",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CSV2DMLI",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
